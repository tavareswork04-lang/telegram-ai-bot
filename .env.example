# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=TON_TOKEN_ICI

# Clé API OpenAI (ou compatible : Kimi, Groq, etc.)
OPENAI_API_KEY=TON_API_KEY_ICI

# URL de base de l'API
# Pour Kimi : https://api.moonshot.cn/v1
# Pour Groq  : https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Modèle
MODEL=gpt-4o-mini

# Ton User ID Telegram (via @userinfobot)
ALLOWED_USER_ID=TON_USER_ID_ICI